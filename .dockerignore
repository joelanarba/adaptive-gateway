# Build context is ./gateway; keep the image lean and reproducible.

# Python bytecode / caches
__pycache__/
*.py[cod]
*.pyc
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Virtual environments
venv/
.venv/
env/

# Version control
.git/
.gitignore

# Secrets and local env (never bake into the image)
.env
.env.*
*.pem
*.key

# Project tooling / docs (not needed at runtime)
tasks/
benchmarks/results/
*.md

# Tests (optional in the runtime image)
tests/

# Editor / OS cruft
.vscode/
.idea/
.DS_Store
